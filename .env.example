# PostgreSQL
DATABASE_URL=postgresql://trakt:trakt@localhost:5432/trakt_dashboard

# KeyDB / Redis (for BullMQ job queue)
REDIS_URL=redis://localhost:6379

# Docker images (used by docker-compose.yml)
API_IMAGE=ghcr.io/inorihimea/trakt-dashboard-api:latest
WEB_IMAGE=ghcr.io/inorihimea/trakt-dashboard-web:latest

# Trakt API — https://trakt.tv/oauth/applications
TRAKT_CLIENT_ID=your_trakt_client_id
TRAKT_CLIENT_SECRET=your_trakt_client_secret
TRAKT_REDIRECT_URI=http://localhost:3001/auth/callback

# TMDB API — https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key

# TVDB API — https://thetvdb.com/dashboard/account/apikey
TVDB_API_KEY=your_tvdb_api_key

# App
API_PORT=3001
API_SECRET=change_me_to_a_random_string_32chars
FRONTEND_URL=http://localhost:5173

# Sync config (minutes)
SYNC_INTERVAL_MINUTES=15
