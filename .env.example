# PostgreSQL
DATABASE_URL=postgresql://trakt:trakt@localhost:5432/trakt_dashboard

# KeyDB / Redis (for BullMQ job queue)
REDIS_URL=redis://localhost:6379

# Docker images (used by docker-compose.yml)
API_IMAGE=ghcr.io/inorihimea/trakt-dashboard-api:latest
WEB_IMAGE=ghcr.io/inorihimea/trakt-dashboard-web:latest

# Trakt API — https://trakt.tv/oauth/applications
TRAKT_CLIENT_ID=your_trakt_client_id
TRAKT_CLIENT_SECRET=your_trakt_client_secret
TRAKT_REDIRECT_URI=http://localhost/auth/callback

# TMDB API — https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key

# TVDB API — https://thetvdb.com/dashboard/account/apikey
TVDB_API_KEY=your_tvdb_api_key

# App
API_PORT=3001
API_SECRET=change_me_to_a_random_string_32chars
FRONTEND_URL=http://localhost:5173
VITE_API_BASE=http://localhost:3001

# Sync config (minutes)
SYNC_INTERVAL_MINUTES=15

# Web Push (optional) — airing reminders. Generate a key pair with:
#   npx web-push generate-vapid-keys
# Leave unset to disable push (the feature degrades gracefully).
# VAPID_PUBLIC_KEY=your_vapid_public_key
# VAPID_PRIVATE_KEY=your_vapid_private_key
# VAPID_SUBJECT=mailto:you@example.com

# Cloud backup providers (optional) — Google Drive / OneDrive need a self-registered
# OAuth app; the Settings → Backup cards stay hidden until these are set.
# Full walkthrough: docs/cloud-backup-setup.md
# (WebDAV and S3 need no env vars — configure them directly in Settings → Backup.)
# GDRIVE_CLIENT_ID=xxxx.apps.googleusercontent.com
# GDRIVE_CLIENT_SECRET=your_gdrive_client_secret
# ONEDRIVE_CLIENT_ID=00000000-0000-0000-0000-000000000000

# HTTP Proxy (optional) — for environments where TMDB/Trakt are not directly accessible
# HTTP_PROXY=http://proxy.example.com:7890
# HTTPS_PROXY=http://proxy.example.com:7890
