{
    "$schema": "https://turbo.build/schema.json",
    "ui": "tui",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": ["dist/**"]
        },
        "dev": {
            "dependsOn": ["^build"],
            "cache": false,
            "persistent": true
        },
        "typecheck": {
            "dependsOn": ["^typecheck"],
            "outputs": []
        },
        "test": {
            "dependsOn": ["^typecheck"],
            "outputs": []
        },
        "test:coverage": {
            "dependsOn": ["^typecheck"],
            "outputs": ["coverage/**"]
        },
        "lint": {
            "outputs": []
        },
        "db:generate": {
            "cache": false,
            "env": ["DATABASE_URL"]
        },
        "db:migrate": {
            "dependsOn": ["db:generate"],
            "cache": false,
            "env": ["DATABASE_URL"]
        }
    }
}
