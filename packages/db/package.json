{
    "name": "@trakt-dashboard/db",
    "version": "0.48.4",
    "private": true,
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "default": "./src/index.ts"
        }
    },
    "scripts": {
        "build": "tsc -p tsconfig.json --noEmit",
