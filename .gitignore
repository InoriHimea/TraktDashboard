node_modules
dist
.env
*.local
.turbo
*.log
.DS_Store

# Compiled TypeScript artifacts — should never appear in src/
# (web uses noEmit:true, api outputs to dist/)
apps/web/src/**/*.js
apps/web/src/**/*.js.map
apps/web/src/**/*.d.ts
apps/web/src/**/*.d.ts.map
!apps/web/src/vite-env.d.ts
apps/api/src/**/*.js
apps/api/src/**/*.js.map
apps/api/src/**/*.d.ts
apps/api/src/**/*.d.ts.map
# Config-level compiled artifacts
apps/web/vite.config.js
apps/web/vite.config.js.map
apps/web/vite.config.d.ts
apps/web/vite.config.d.ts.map
# packages — main/types point directly to .ts, no build output needed in src
packages/db/src/**/*.js
packages/db/src/**/*.js.map
packages/db/src/**/*.d.ts
packages/db/src/**/*.d.ts.map
packages/db/drizzle.config.js
packages/db/drizzle.config.js.map
packages/db/drizzle.config.d.ts
packages/db/drizzle.config.d.ts.map
packages/types/src/**/*.js
packages/types/src/**/*.js.map
packages/types/src/**/*.d.ts
packages/types/src/**/*.d.ts.map
