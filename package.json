{
    "name": "trakt-dashboard",
    "version": "0.82.3",
    "private": true,
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build",
        "typecheck": "turbo run typecheck",
        "typecheck:build": "tsc -b tsconfig.build.json",
        "test": "turbo run test",
        "test:coverage": "turbo run test:coverage",
        "lint": "eslint . && prettier --check .",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test:e2e": "playwright test",
        "ci": "pnpm lint && pnpm typecheck && pnpm build && pnpm test:coverage",
        "audit": "pnpm audit --audit-level=moderate",
        "commitlint": "commitlint --edit",
        "prepare": "husky",
        "db:generate": "turbo run db:generate",
        "db:migrate": "turbo run db:migrate",
        "docker:build": "bash scripts/build-images.sh",
        "docker:build:push": "PUSH=true bash scripts/build-images.sh"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.0.2",
        "@commitlint/config-conventional": "^21.0.2",
        "@eslint/js": "^9.39.4",
        "@playwright/test": "^1.60.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react-hooks": "^7.1.1",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.7",
        "prettier": "^3.8.3",
        "turbo": "^2.9.16",
        "typescript": "^5.7.2",
        "typescript-eslint": "^8.60.1"
    },
    "pnpm": {
        "overrides": {
            "bun-types": "1.3.14",
            "esbuild": "0.27.7",
            "minimatch@10>brace-expansion": "5.0.6"
        }
    },
    "engines": {
        "node": ">=20",
        "pnpm": ">=9"
    },
    "packageManager": "pnpm@10.19.0"
}
